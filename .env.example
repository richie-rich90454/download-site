# Server port
PORT=3000

# Directory for cached assets
CACHE_DIR=./cache

# Application configuration as a JSON array
# Each app needs an id, repo (owner/name), and display name
APPS=[{"id":"myapp","repo":"owner/repo","name":"My App"}]

# GitHub authentication (optional but recommended for higher API limits)
GITHUB_TOKEN=ghp_your_token_here

# GitHub App authentication alternative (optional)
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Optional JSON config file path that overrides environment variables
# CONFIG_PATH=./config.json

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# CORS origin (optional)
# CORS_ORIGIN=https://example.com
