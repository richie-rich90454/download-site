{
    "name": "download-server",
    "version": "1.0.0",
    "description": "",
    "main": "dist/server/main.js",
    "type": "module",
    "scripts": {
        "build": "npm run build:server && npm run build:public",
        "build:server": "tsc -b",
        "build:public": "vite build",
        "typecheck": "tsc -b",
        "dev:public": "vite",
        "test": "vitest run",
        "lint": "eslint src tests --ext .ts,.tsx,.js,.jsx",
        "lint:fix": "eslint src tests --ext .ts,.tsx,.js,.jsx --fix",
        "format": "prettier --write \"src/**/*\" \"tests/**/*\" \"public/**/*\" \"*.{ts,js,json,css,html,md}\"",
        "format:check": "prettier --check \"src/**/*\" \"tests/**/*\" \"public/**/*\" \"*.{ts,js,json,css,html,md}\"",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,css,html}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{ts,tsx}": "node -e \"require('child_process').execSync('npm run typecheck',{stdio:'inherit'})\""
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@fastify/cors": "^11.3.0",
        "@fastify/helmet": "^13.1.0",
        "@fastify/rate-limit": "^11.1.0",
        "@fastify/static": "^10.1.0",
        "@fastify/swagger": "^9.8.1",
        "@fastify/swagger-ui": "^6.1.0",
        "@opentelemetry/api": "^1.9.1",
        "better-sqlite3": "^12.11.1",
        "dompurify": "^3.4.12",
        "dotenv": "^17.4.2",
        "fastify": "^5.10.0",
        "highlight.js": "^11.11.1",
        "marked": "^18.0.6",
        "msgpackr": "^2.0.4",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "prom-client": "^15.1.3",
        "reflect-metadata": "^0.2.2",
        "tsyringe": "^4.10.0",
        "ua-parser-js": "^2.0.10",
        "undici": "^8.7.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/better-sqlite3": "^7.6.13",
        "@types/dompurify": "^3.0.5",
        "@types/node": "^26.1.1",
        "@types/ua-parser-js": "^0.7.39",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "eslint": "^10.7.0",
        "eslint-config-prettier": "^10.1.8",
        "happy-dom": "^20.10.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.8.1",
        "tsx": "^4.23.1",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    }
}
